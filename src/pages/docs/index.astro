---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocsShell from '../../components/DocsShell.astro';
import Icon from '../../components/Icon.astro';

const cards = [
  { title: 'Introduction', href: '/docs/introduction/', desc: 'What Fastify is and the principles behind it.', icon: 'heart' },
  { title: 'Getting started', href: '/docs/guides/getting-started/', desc: 'Install Fastify and write your first server.', icon: 'bolt' },
  { title: 'Plugins guide', href: '/docs/guides/plugins-guide/', desc: 'Compose your app with encapsulated plugins.', icon: 'plug' },
  { title: 'Validation', href: '/docs/reference/validation/', desc: 'Validate and serialize with JSON Schema.', icon: 'schema' },
  { title: 'Server reference', href: '/docs/reference/server/', desc: 'Factory options, hooks and lifecycle.', icon: 'log' },
  { title: 'Plugins reference', href: '/docs/reference/plugins/', desc: 'The plugin system and decorators.', icon: 'ts' },
];
---
<BaseLayout title="Documentation — Fastify" description="Guides and API reference for the Fastify web framework.">
  <DocsShell current="" prose={false}>
    <div>
      <p class="eyebrow">// documentation</p>
      <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight">Documentation</h1>
      <p class="mt-4 max-w-2xl text-lg text-fg-soft">
        Learn Fastify from the ground up. Start with the guides, then dig into the
        reference. In production this section is generated from the versioned Markdown
        in the <a href="https://github.com/fastify/fastify" class="text-amber-ink underline decoration-[var(--border-strong)] underline-offset-2">fastify/fastify</a> repository.
      </p>
      <div class="mt-8 grid gap-3 sm:grid-cols-2">
        {cards.map((c) => (
          <a href={c.href} class="card group flex items-start gap-4 p-5 transition-colors hover:border-[var(--border-strong)]">
            <span class="grid size-10 shrink-0 place-items-center rounded-lg border border-[var(--border)] bg-[var(--surface-2)] text-amber-ink">
              <Icon name={c.icon} size={20} />
            </span>
            <div>
              <div class="flex items-center gap-1.5 font-display text-lg font-semibold text-fg group-hover:text-amber-ink">
                {c.title} <Icon name="arrow" size={15} class="opacity-0 transition-opacity group-hover:opacity-100" />
              </div>
              <p class="mt-1 text-sm text-fg-soft">{c.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </DocsShell>
</BaseLayout>
