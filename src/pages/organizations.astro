---
import ButtonLink from "../components/ButtonLink.astro";
import Icon from "../components/Icon.astro";
import PageHeader from "../components/PageHeader.astro";
import PersonAvatar from "../components/PersonAvatar.astro";
import {
	COLLABORATORS,
	LEADS,
	PAST_COLLABORATORS,
	SITE,
	SPONSORS,
} from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const collaborator = SPONSORS.filter((s) => s.tier === "collaborator");
const sponsors = SPONSORS.filter((s) => s.tier === "sponsor");
---

<BaseLayout
  title="Organizations & Team — Fastify"
  description="Organizations using Fastify, sponsors, and the maintainer team."
>
  <PageHeader eyebrow="// who is using fastify" title="Organizations & team">
    Fastify proudly powers a large ecosystem of organizations and products,
    with over{" "}
    {SITE.downloads} downloads per month.
  </PageHeader>

  <section class="mx-auto max-w-7xl px-4 py-14 sm:px-6">
    <p class="eyebrow">// collaborators</p>
    <h2 class="mt-3 font-display text-2xl font-semibold">
      Collaborators' organizations
    </h2>
    <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {
        collaborator.map((c) => (
          <a
            href={c.url}
            target="_blank"
            rel="noopener noreferrer"
            class="card group flex items-center justify-between p-5 transition-colors hover:border-border-strong"
          >
            <span class="font-display text-lg font-medium text-fg-soft group-hover:text-fg">
              {c.name}
            </span>
            <Icon
              name="external"
              size={16}
              class="text-muted opacity-0 transition-opacity group-hover:opacity-100"
            />
          </a>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-6 sm:px-6">
    <div
      class="card flex flex-col items-start gap-6 p-8 sm:flex-row sm:items-center sm:justify-between"
    >
      <div>
        <p class="eyebrow">// sponsors</p>
        <h2 class="mt-3 font-display text-2xl font-semibold">
          Kindly sponsored by
        </h2>
        <div class="mt-3 flex flex-wrap gap-x-6 gap-y-2">
          {
            sponsors.map((s) => (
              <a
                href={s.url}
                target="_blank"
                rel="noopener noreferrer"
                class="font-display text-lg text-fg-soft hover:text-amber-ink"
              >
                {s.name}
              </a>
            ))
          }
        </div>
      </div>
      <div class="flex flex-wrap gap-3">
        <ButtonLink href="https://github.com/sponsors/fastify" external>
          <Icon name="github" size={18} /> Sponsor
        </ButtonLink>
        <ButtonLink
          href="https://opencollective.com/fastify"
          variant="secondary"
          external
        >
          Open Collective
        </ButtonLink>
      </div>
    </div>
  </section>

  <section id="team" class="mx-auto max-w-7xl px-4 py-14 sm:px-6">
    <p class="eyebrow">// lead maintainers</p>
    <h2 class="mt-3 font-display text-2xl font-semibold">The team</h2>
    <div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
      {LEADS.map((p) => <PersonAvatar person={p} variant="card" />)}
    </div>

    <p class="eyebrow mt-14">// collaborators</p>
    <h3 class="mt-3 font-display text-xl font-semibold">Collaborators</h3>
    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
      {COLLABORATORS.map((p) => <PersonAvatar person={p} variant="chip" />)}
    </div>

    <p class="eyebrow mt-14">// past collaborators</p>
    <h3 class="mt-3 font-display text-xl font-semibold">Past collaborators</h3>
    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
      {PAST_COLLABORATORS.map((p) => <PersonAvatar person={p} variant="chip" />)}
    </div>
  </section>
</BaseLayout>
