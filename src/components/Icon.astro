  check: '<path d="M5 12l5 5L20 7"/>',
  npm: '<path d="M3 5h18v12h-9v2H8v-2H3V5Zm3 3v6h2V9h1v5h2V8H6Zm7 0v6h4v-1h-2V8h-2Z"/>',
  external: '<path d="M14 5h5v5M19 5l-9 9M11 5H5v14h14v-6"/>',
