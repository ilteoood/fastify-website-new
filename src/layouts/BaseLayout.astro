---
import "@fontsource-variable/inter";
import "@fontsource-variable/space-grotesk";
import "@fontsource-variable/jetbrains-mono";
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import Search from "../components/Search.astro";
import { SITE } from "../data/site";
import { withBase } from "../lib/href";

interface Props {
	title?: string;
	description?: string;
	hideChrome?: boolean;
}
const {
	title = `${SITE.name} — ${SITE.tagline}`,
	description = SITE.description,
	hideChrome = false,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE.url).href;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="theme-color" content="#0a0b0d" />
    <script is:inline>
      (() => {
        try {
          const t = localStorage.getItem('theme');
          if (t === 'light') document.documentElement.setAttribute('data-theme', 'light');
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen bg-bg text-fg antialiased">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-100 focus:rounded-md focus:bg-amber focus:px-4 focus:py-2 focus:text-[#0a0b0d]">
      Skip to content
    </a>
    {!hideChrome && <Nav />}
    <main id="main">
      <slot />
    </main>
    {!hideChrome && <Footer />}
    <Search />

    <script>
      // Theme toggle
      const applyTheme = (theme: string) => {
        if (theme === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
        } else {
          document.documentElement.removeAttribute('data-theme');
        }
        try { localStorage.setItem('theme', theme); } catch (e) {}
      };
      document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const isLight = document.documentElement.getAttribute('data-theme') === 'light';
          applyTheme(isLight ? 'dark' : 'light');
        });
      });

      // Mobile menu
      const menu = document.querySelector('[data-mobile-menu]');
      const openMenu = () => menu?.classList.remove('hidden');
      const closeMenu = () => menu?.classList.add('hidden');
      document.querySelector('[data-menu-open]')?.addEventListener('click', openMenu);
      document.querySelector('[data-menu-close]')?.addEventListener('click', closeMenu);
      menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));

      // Live GitHub star count — fetched client-side when the page loads.
      (async () => {
        const els = document.querySelectorAll('[data-github-stars]');
        if (!els.length) return;
        const format = (n: number) =>
          n >= 1000 ? `${(n / 1000).toFixed(1).replace(/\.0$/, '')}k` : String(n);
        try {
          let count = Number(sessionStorage.getItem('fastify-stars')) || 0;
          if (!count) {
            const res = await fetch('https://api.github.com/repos/fastify/fastify');
            if (!res.ok) return;
            const data = await res.json();
            count = data.stargazers_count;
            try { sessionStorage.setItem('fastify-stars', String(count)); } catch (e) {}
          }
          if (count) els.forEach((el) => { el.textContent = format(count); });
        } catch (e) {}
      })();

      // Live npm monthly downloads — fetched client-side when the page loads.
      (async () => {
        const els = document.querySelectorAll('[data-npm-downloads]');
        if (!els.length) return;
        const format = (n: number) =>
          n >= 1_000_000
            ? `${(n / 1_000_000).toFixed(1).replace(/\.0$/, '')}M`
            : n >= 1000
              ? `${(n / 1000).toFixed(1).replace(/\.0$/, '')}k`
              : String(n);
        try {
          let count = Number(sessionStorage.getItem('fastify-downloads')) || 0;
          if (!count) {
            const res = await fetch('https://api.npmjs.org/downloads/point/last-month/fastify');
            if (!res.ok) return;
            const data = await res.json();
            count = data.downloads;
            try { sessionStorage.setItem('fastify-downloads', String(count)); } catch (e) {}
          }
          if (count) els.forEach((el) => { el.textContent = format(count); });
        } catch (e) {}
      })();
    </script>
  </body>
</html>
