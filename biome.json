{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"files": {
		"includes": [
			"**",
			"!**/dist",
			"!**/.astro",
			"!**/.cache",
			"!src/content/docs",
			"!public/docs",
			"!src/data/versions.json",
			"!**/package-lock.json",
			"!**/pnpm-lock.yaml",
			"!**/*.svg",
			"!skills-lock.json",
			"!**/.tokensave"
		]
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		},
		"formatter": {
			"enabled": true
		}
	},
	"formatter": {
		"formatWithErrors": true
	},
	"overrides": [
		{
			"includes": ["**/*.astro"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedImports": "off",
						"noUnusedVariables": "off"
					},
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		}
	]
}
