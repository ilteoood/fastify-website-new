{
  "name": "fastify-website",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "fetch:docs": "node scripts/fetch-docs.mjs",
    "predev": "node scripts/fetch-docs.mjs && node scripts/build-plugin-list.mjs && node scripts/download-benchmarks.mjs",
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "node scripts/fetch-docs.mjs && node scripts/build-plugin-list.mjs && node scripts/download-benchmarks.mjs",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "oxlint && oxfmt --check"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/inter": "^5.3.0",
    "@fontsource-variable/jetbrains-mono": "^5.3.0",
    "@fontsource-variable/space-grotesk": "^5.3.0",
    "@lucide/astro": "^1.25.0",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^7.1.3",
    "astro-inference": "^0.2.6",
    "isomorphic-dompurify": "^3.19.0",
    "marked": "^18.0.7",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "pagefind": "^1.5.2"
  }
}
